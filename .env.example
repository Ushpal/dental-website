# Shine Dental Clinic example environment variables
# Copy this file to .env and update values for your local environment.

NODE_ENV=development
PORT=3000
# Database configuration
DATABASE_URL=postgres://user:password@localhost:5432/shine_dental_clinic
# Authentication
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=7d

# Email settings
EMAIL_SERVICE=Gmail
EMAIL_USER=your-email@example.com
EMAIL_PASSWORD=your-email-password

# Application settings
APP_NAME=Shine Dental Clinic
APP_URL=http://localhost:3000
